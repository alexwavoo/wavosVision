# Canonical portfolio origin (use in Shopify theme: point logo or “Work” nav here)
REACT_APP_SITE_URL=https://wavos.vision

# Shopify storefront (subdomain or custom domain)
REACT_APP_STORE_URL=https://store.wavos.vision

# Optional: GA4 measurement ID. When set, gtag loads with linker domains derived from the two URLs above.
# Mirror the same ID + linker on the Shopify side (Online Store > Preferences, or theme gtag) so sessions stitch across subdomains.
# REACT_APP_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

#
# Shopify theme (manual, not this repo): Online Store > Themes > Edit code
# - Header: link logo or add “Work” → REACT_APP_SITE_URL value above
# - Align colors/fonts with src/styles/variables.css (e.g. background #111111, text #fdf8dc, body Roboto)
