# Copy to .env.push (gitignored) for non-interactive theme push from a real terminal.
# Get a password: Shopify Admin → Apps → Theme Access (or use `shopify auth login` instead).

# Your permanent admin domain, e.g. wavos-vision.myshopify.com (not store.wavos.vision)
SHOPIFY_FLAG_STORE=your-store.myshopify.com

# Theme Access app password (starts with shptka_)
SHOPIFY_CLI_THEME_TOKEN=
